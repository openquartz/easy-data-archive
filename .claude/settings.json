{
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(git *)",
      "Read(easyarchive-*/**/*)",
      "Edit(easyarchive-*/**/*)",
      "Write(easyarchive-*/**/*)",
      "Glob(easyarchive-*/**/*)",
      "Bash(ls)",
      "Bash(find)",
      "Bash(cat)",
      "Bash(pwd)",
      "Bash(echo)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(docker *)",
      "Bash(kubectl *)"
    ],
    "defaultMode": "default"
  },
  "language": "chinese",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_response.filePath // .tool_input.file_path'); if [[ $file =~ \\.(java|xml|properties)$ ]]; then echo '编译变更的文件...' && mvn compile -q -DskipTests -pl easyarchive-core 2>/dev/null || true; fi",
            "timeout": 45,
            "statusMessage": "验证代码编译..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== EasyArchive 项目环境 ===' && echo 'Java 版本:' && java -version 2>&1 | head -1 && echo 'Maven 版本:' && mvn -v | head -1 && echo '项目状态:' && git status --porcelain | wc -l && echo '个未提交文件'",
            "timeout": 15,
            "statusMessage": "检查项目环境..."
          }
        ]
      }
    ]
  },
  "todoFeatureEnabled": true,
  "verbose": true,
  "autoCompactEnabled": true,
  "cleanupPeriodDays": 30,
  "respectGitignore": true,
  "terminalProgressBarEnabled": true,
  "showTurnDuration": true,
  "fileCheckpointingEnabled": true
}